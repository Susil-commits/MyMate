# ============================================================
# PRODUCTION ENV VARS (already configured code handles these)
# ============================================================
# Render (backend)  -> https://mymate-965m.onrender.com
# Vercel (frontend) -> https://my-mate-tawny.vercel.app
#
# RENDER service environment variables:
#   CLIENT_URL           = https://my-mate-tawny.vercel.app
#   MONGO_URI            = <your MongoDB Atlas connection string>
#   JWT_SECRET           = <long random string>
#   ADMIN_CODE           = <your admin code>
#   RAZORPAY_KEY_ID      = rzp_test_...
#   RAZORPAY_KEY_SECRET  = <razorpay secret>
#   CLOUDINARY_*         = (optional, leave blank for local disk)
#   NODE_ENV             = production
#
# VERCEL project environment variables (set BEFORE first build):
#   VITE_API_URL         = https://mymate-965m.onrender.com/api
#   VITE_RAZORPAY_KEY_ID = rzp_test_...   (same as backend RAZORPAY_KEY_ID)
#
# NOTE: No trailing slashes needed (code normalizes them).
# NOTE: SMTP/email is disabled and will be re-enabled later.
# ============================================================

# ---- Local dev (backend/.env) ----
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mymate
JWT_SECRET=replace_with_a_long_random_string
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
ADMIN_CODE=replace_with_a_strong_code

# ---- Local dev (frontend/.env) ----
VITE_API_URL=http://localhost:5000/api
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
